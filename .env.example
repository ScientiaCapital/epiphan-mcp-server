# Epiphan Pearl MCP Server Configuration
# Copy this file to .env and fill in your values

# ============================================================
# Device Configuration
# ============================================================

# Pearl device(s) - comma-separated for multiple devices
# Examples:
#   PEARL_DEVICES=192.168.1.100
#   PEARL_DEVICES=192.168.1.100,192.168.1.101,192.168.1.102
#   PEARL_DEVICES=pearl-room101.local,pearl-room102.local
PEARL_DEVICES=

# Authentication
PEARL_USERNAME=admin
PEARL_PASSWORD=

# Optional: API key auth (if supported by your firmware version)
# PEARL_API_KEY=

# ============================================================
# Connection Settings
# ============================================================

# Use HTTPS instead of HTTP (requires SSL cert on Pearl)
PEARL_USE_HTTPS=false

# Request timeout in seconds
PEARL_TIMEOUT=30.0

# Verify SSL certificates (set to false for self-signed certs)
PEARL_VERIFY_SSL=true

# ============================================================
# Fleet Settings
# ============================================================

# Fleet name for identification
PEARL_FLEET_NAME=default

# Maximum concurrent fleet operations (1-100, default: 10)
# PEARL_MAX_CONCURRENT_OPS=10

# ============================================================
# AI/LLM Configuration (Optional)
# ============================================================
# These settings enable AI-powered video analysis features.
# Without OPENROUTER_API_KEY, the system uses mock responses (development mode).

# OpenRouter API key for multi-model AI access
# Get one at: https://openrouter.ai/keys
# Supports Claude, Gemini, DeepSeek, Qwen and 300+ other models
OPENROUTER_API_KEY=

# Vision model for scene analysis (optional, has smart defaults)
# Options: anthropic/claude-sonnet-4, google/gemini-2.0-flash-001, qwen/qwen2.5-vl-72b-instruct
# LLM_VISION_MODEL=google/gemini-2.0-flash-001

# Model for OCR/text extraction (Qwen excels at this)
# LLM_OCR_MODEL=qwen/qwen2.5-vl-72b-instruct

# Model for quick quality checks (fast, cheap)
# LLM_QUALITY_MODEL=google/gemini-2.0-flash-001

# Model for text-only tasks like reasoning
# LLM_TEXT_MODEL=deepseek/deepseek-chat-v3-0324

# Cost controls
# LLM_MAX_TOKENS=1000
# LLM_RATE_LIMIT=20

# Enable mock mode (returns fake responses, no API calls)
# LLM_MOCK_MODE=false

# ============================================================
# Health Thresholds
# ============================================================

# Storage usage percent to trigger warning (0-100)
PEARL_STORAGE_WARNING_PERCENT=80.0

# Storage usage percent considered critical (0-100)
PEARL_STORAGE_CRITICAL_PERCENT=90.0

# Health score weights (should sum to 100 for 0-100 score range)
PEARL_HEALTH_SCORE_STORAGE_WEIGHT=50
PEARL_HEALTH_SCORE_RECORDING_WEIGHT=50

# ============================================================
# Retry Settings
# ============================================================

# Max retry attempts for API calls (0-10)
PEARL_MAX_RETRIES=3

# Base retry delay in seconds
PEARL_RETRY_BASE_DELAY=1.0

# Max retry delay in seconds
PEARL_RETRY_MAX_DELAY=30.0

# ============================================================
# Panopto CMS Integration (Optional)
# ============================================================
# Configure for Panopto video platform integration

# PANOPTO_HOST=panopto.university.edu
# PANOPTO_CLIENT_ID=your-oauth-client-id
# PANOPTO_USERNAME=service@university.edu
# PANOPTO_PASSWORD=your-password
# PANOPTO_CLIENT_SECRET=optional-client-secret

# ============================================================
# Kaltura CMS Integration (Optional)
# ============================================================
# Configure for Kaltura video platform integration
# Get credentials from Kaltura KMC > Settings > Integration Settings > App Tokens

# Partner ID (numeric, from KMC Settings)
# KALTURA_PARTNER_ID=12345

# App Token credentials (create in KMC > Integration Settings > App Tokens)
# KALTURA_APP_TOKEN_ID=0_abc123xyz
# KALTURA_APP_TOKEN=your-app-token-secret

# Service URL (optional, defaults to kaltura.com)
# KALTURA_SERVICE_URL=https://www.kaltura.com

# User ID for operations (optional)
# KALTURA_USER_ID=service@university.edu

# ============================================================
# Epiphan Cloud Integration (Optional)
# ============================================================
# Configure for cloud-based fleet management via go.epiphan.cloud
# Get your API token from: Epiphan Cloud > Settings > API Tokens

# API Bearer token (required for cloud features)
# EPIPHAN_CLOUD_TOKEN=your-bearer-token

# Cloud host (optional, defaults to go.epiphan.cloud)
# EPIPHAN_CLOUD_HOST=go.epiphan.cloud

# ============================================================
# Testing
# ============================================================

# Pearl IP for integration tests (optional)
# PEARL_TEST_IP=192.168.1.100
