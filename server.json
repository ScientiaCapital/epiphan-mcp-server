{
  "name": "epiphan-pearl",
  "display_name": "Epiphan Pearl MCP Server",
  "description": "AI-native control for Epiphan Pearl video capture devices — recording, streaming, fleet management, CMS integrations, and PTZ camera control through the Model Context Protocol.",
  "version": "1.3.0",
  "author": {
    "name": "Tim Kipper",
    "url": "https://github.com/ScientiaCapital"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ScientiaCapital/epiphan-mcp-server"
  },
  "license": "MIT",
  "transport": "stdio",
  "tools_count": 130,
  "categories": ["hardware", "video", "av-control", "iot"],
  "integrations": [
    "Epiphan Pearl",
    "Panopto",
    "Kaltura",
    "Opencast",
    "YuJa",
    "Echo360",
    "Q-SYS",
    "YouTube Live",
    "Epiphan EC20",
    "Epiphan Cloud",
    "OpenRouter (Vision LLMs)"
  ],
  "installation": {
    "pip": "Not yet published to PyPI — install from source (below)",
    "source": "git clone https://github.com/ScientiaCapital/epiphan-mcp-server.git && pip install -e '.[dev]'"
  },
  "configuration": {
    "required": ["PEARL_DEVICES", "PEARL_USERNAME", "PEARL_PASSWORD"],
    "optional": ["PEARL_USE_HTTPS", "PEARL_TIMEOUT", "OPENROUTER_API_KEY"]
  }
}
